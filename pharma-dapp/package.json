{
  "name": "pharma-dapp",
  "version": "1.0.0",
  "description": "Pharmaceutical Supply Chain Blockchain DApp",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
"events": "node src/events.js",
