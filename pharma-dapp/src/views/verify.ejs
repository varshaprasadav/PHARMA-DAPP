<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>QR Verify – PharmaChain</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
  <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <%- include('_nav') %>

  <div class="max-w-xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-bold text-indigo-700 mb-2">📱 QR Code Verification</h1>
    <p class="text-gray-500 text-sm mb-6">
      Role: <strong>Customer</strong> — Verify medicine authenticity by scanning QR or entering Medicine ID.
    </p>

    <div id="walletInfo" class="hidden bg-indigo-50 border border-indigo-200 rounded-lg p-3 mb-4 text-sm text-indigo-700">
      👛 <strong id="walletAddress"></strong> &nbsp;|&nbsp; 🌐 <strong id="networkName"></strong>
    </div>
    <button id="connectBtn" onclick="connectWallet()"
      class="bg-indigo-600 text-white px-4 py-2 rounded mb-6 hover:bg-indigo-700">
      🔗 Connect Wallet
    </button>

    <div id="errorMsg"   class="hidden bg-red-100   text-red-700   border border-red-300   rounded p-3 mb-4"></div>
    <div id="successMsg" class="hidden bg-green-100 text-green-700 border border-green-300 rounded p-3 mb-4"></div>

    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <h2 class="font-bold text-gray-700 mb-3">🖨️ Generate QR for a Medicine</h2>
      <div class="flex gap-2 mb-4">
        <input id="genMedicineId" placeholder="Enter Medicine ID (e.g. MED001)"
          class="flex-1 border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
        <button onclick="handleGenerate()"
          class="bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 text-sm">
          Generate
        </button>
      </div>
      <div id="qrPreviewBox" class="hidden text-center">
        <div id="qrPreviewCanvas" class="inline-block border rounded p-2 bg-white shadow"></div>
        <p class="text-xs text-gray-400 mt-2">QR Code Preview</p>
        <button onclick="downloadQR(document.getElementById('genMedicineId').value)"
          class="mt-2 bg-gray-100 hover:bg-gray-200 text-gray-700 px-3 py-1 rounded text-xs">
          ⬇ Download QR
        </button>
      </div>
      <div id="qrBox" class="hidden text-center mt-3">
        <img id="qrImage" src="" alt="Saved QR" class="mx-auto border rounded" style="width:160px" />
        <p class="text-xs text-gray-400 mt-1">Saved QR (PNG)</p>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <h2 class="font-bold text-gray-700 mb-3">📷 Scan QR Code with Camera</h2>
      <div id="qr-reader" class="w-full rounded overflow-hidden border mb-3 bg-gray-100" style="min-height:60px"></div>
      <div class="flex gap-2 mb-3">
        <button id="startScanBtn" onclick="handleStartScan()"
          class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 text-sm">
          ▶ Start Camera
        </button>
        <button id="stopScanBtn" onclick="stopQRScanner()" disabled
          class="bg-gray-400 text-white px-4 py-2 rounded text-sm opacity-50">
          ⏹ Stop
        </button>
      </div>
      <div class="border-t pt-3">
        <p class="text-xs text-gray-500 mb-2">Or upload a QR image:</p>
        <input type="file" id="qrFileInput" accept="image/*"
          onchange="handleFileScan(this.files[0])"
          class="text-sm text-gray-600 file:mr-2 file:py-1 file:px-3 file:border file:rounded file:text-sm file:bg-indigo-50 file:text-indigo-700" />
        <div id="qr-file-reader" class="hidden"></div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <h2 class="font-bold text-gray-700 mb-3">🔎 Enter Medicine ID Manually</h2>
      <div class="flex gap-2">
        <input id="manualId" placeholder="Medicine ID (e.g. MED001)"
          class="flex-1 border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
        <button onclick="verifyById(document.getElementById('manualId').value)"
          class="bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 text-sm">
          Verify
        </button>
      </div>
    </div>

    <div id="verifyResult" class="hidden bg-white rounded-lg shadow p-6 border-l-4 border-green-500">
      <h3 class="font-bold text-green-700 mb-3">✅ Medicine Verified on Blockchain</h3>
      <div id="verifyDetails" class="text-sm space-y-1 mb-4"></div>
      <h4 class="font-semibold text-gray-600 mb-2">📋 Lifecycle Timeline</h4>
      <div id="verifyTimeline"></div>
    </div>
  </div>

  <%- include('_loading') %>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/5.7.2/ethers.umd.min.js"></script>
  <script>const CONTRACT_ADDRESS = "<%= CONTRACT_ADDRESS %>";</script>
  <script src="/ui.js"></script>
  <script src="/qr.js"></script>
  <script>
    async function handleGenerate() {
      if (!contract) return alert("Connect wallet first.");
      const id = document.getElementById("genMedicineId").value.trim();
      if (!id) return alert("Enter a Medicine ID.");
      setLoading(true, "Fetching medicine data...");
      const m = await getMedicine(id);
      setLoading(false);
      if (!m || !m.medicineId) return;
      document.getElementById("qrPreviewBox").classList.remove("hidden");
      generateQRCode("qrPreviewCanvas", m);
      const dbRes = await fetch(`/api/medicine/${id}`).catch(() => null);
      if (dbRes && dbRes.ok) {
        const db = await dbRes.json();
        if (db.qrPath) showQRImage(db.qrPath, "qrImage", "qrBox");
      }
    }

    function handleStartScan() {
      startQRScanner("qr-reader", (decodedText) => {
        stopQRScanner();
        const data = parseQRData(decodedText);
        verifyById(data.medicineId);
      }, (err) => showError(err));
    }

    function handleFileScan(file) {
      if (!file) return;
      scanQRFromFile(file, "qr-file-reader", (decodedText) => {
        const data = parseQRData(decodedText);
        verifyById(data.medicineId);
      }, (err) => showError(err));
    }

    async function verifyById(id) {
      if (!id) return alert("Enter a Medicine ID.");
      if (!contract) return alert("Connect wallet first.");
      document.getElementById("errorMsg").classList.add("hidden");
      document.getElementById("verifyResult").classList.add("hidden");
      setLoading(true, "Verifying on blockchain...");
      const m = await getMedicine(id.trim());
      setLoading(false);
      if (!m || !m.medicineId) return;
      document.getElementById("verifyResult").classList.remove("hidden");
      document.getElementById("verifyDetails").innerHTML = [
        ["Medicine ID",  m.medicineId],
        ["Name",         m.name],
        ["Batch No.",    m.batchNumber],
        ["Manufacturer", m.manufacturerName],
        ["Distributor",  m.distributorName  || "—"],
        ["Pharmacy",     m.pharmacyName     || "—"],
        ["Mfg. Date",    m.manufacturingDate],
        ["Expiry Date",  m.expiryDate],
        ["Owner",        truncate(m.currentOwner)],
        ["Last Updated", new Date(m.timestamp * 1000).toLocaleString()],
      ].map(([k, v]) =>
        `<div class="flex justify-between border-b py-1">
          <span class="text-gray-500">${k}</span>
          <span class="font-medium">${v}</span>
        </div>`
      ).join("") +
      `<div class="flex justify-between pt-1">
        <span class="text-gray-500">Status</span>
        <span>${statusBadge(m.currentStatus)}</span>
      </div>`;
      document.getElementById("verifyTimeline").innerHTML = renderTimeline(m.currentStatus);
      document.getElementById("verifyResult").scrollIntoView({ behavior: "smooth" });
    }
  </script>
</body>
</html>
