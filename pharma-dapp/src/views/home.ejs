<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PharmaChain – Home</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">

  <%- include('_nav') %>

  <div class="max-w-5xl mx-auto px-4 py-10">

    <!-- Header -->
    <div class="text-center mb-10">
      <h1 class="text-4xl font-bold text-indigo-700">🏥 PharmaChain</h1>
      <p class="text-gray-500 mt-2 text-2xl">Pharmaceutical Supply Chain on Blockchain </p>
    </div>

    <!-- Wallet Info -->
    <div id="walletInfo" class="hidden bg-indigo-50 border border-indigo-200 rounded-lg p-4 mb-6 text-sm text-indigo-700 flex flex-wrap gap-4">
      <span> Wallet: <strong id="walletAddress"></strong></span>
    </div>

    <!-- Connect Button -->
    <div class="text-center mb-8">
      <button id="connectBtn" onclick="connectWallet()"
        class="bg-indigo-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-indigo-700 transition">
        🔗 Connect MetaMask
      </button>
    </div>

    <!-- Loading spinner for stats -->
    <div id="statsLoading" class="hidden text-center mb-4 text-gray-400 text-sm">
      ⚙️ Loading medicine stats from blockchain...
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <a href="/medicines" class="bg-white rounded-lg shadow p-4 text-center hover:shadow-md hover:border-indigo-300 border border-transparent transition">
        <div class="text-3xl font-bold text-indigo-600" id="totalMedicines">—</div>
        <div class="text-gray-500 text-sm mt-1">Total Medicines</div>
        <div class="text-xs text-indigo-400 mt-1">Click to view all →</div>
      </a>
      <a href="/medicines" class="bg-white rounded-lg shadow p-4 text-center hover:shadow-md hover:border-blue-300 border border-transparent transition">
        <div class="text-3xl font-bold text-blue-500" id="manufacturedCount">—</div>
        <div class="text-gray-500 text-sm mt-1">Manufactured</div>
        <div class="text-xs text-blue-400 mt-1">Click to view →</div>
      </a>
      <a href="/medicines" class="bg-white rounded-lg shadow p-4 text-center hover:shadow-md hover:border-green-300 border border-transparent transition">
        <div class="text-3xl font-bold text-green-500" id="pharmacyCount">—</div>
        <div class="text-gray-500 text-sm mt-1">At Pharmacy</div>
        <div class="text-xs text-green-400 mt-1">Click to view →</div>
      </a>
      <a href="/medicines" class="bg-white rounded-lg shadow p-4 text-center hover:shadow-md hover:border-gray-300 border border-transparent transition">
        <div class="text-3xl font-bold text-gray-500" id="soldCount">—</div>
        <div class="text-gray-500 text-sm mt-1">Sold</div>
        <div class="text-xs text-gray-400 mt-1">Click to view →</div>
      </a>
    </div>

    <!-- Role Guide -->
    <div class="bg-white rounded-lg shadow p-6 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
        <div class="bg-indigo-50 rounded-lg p-4">
          <div class="font-bold text-indigo-700 mb-2">🏭 Account 1 — Manufacturer</div>
          <ul class="text-gray-600 space-y-1 mb-3">
            <li> Add Medicine</li>
            <li>Assign Distributor</li>
          </ul>
          <a href="/add" class="inline-block bg-indigo-600 text-white px-3 py-1 rounded text-xs hover:bg-indigo-700">
            Go to Add Medicine →
          </a>
        </div>
        <div class="bg-yellow-50 rounded-lg p-4">
          <div class="font-bold text-yellow-700 mb-2">🚚 Account 2 — Distributor</div>
          <ul class="text-gray-600 space-y-1 mb-3">
            <li> Confirm Receipt</li>
            <li>Send to Pharmacy</li>
          </ul>
          <a href="/distributor" class="inline-block bg-yellow-500 text-white px-3 py-1 rounded text-xs hover:bg-yellow-600">
            Go to Distributor →
          </a>
        </div>
        <div class="bg-purple-50 rounded-lg p-4">
          <div class="font-bold text-purple-700 mb-2">💊 Account 3 — Pharmacy</div>
          <ul class="text-gray-600 space-y-1 mb-3">
            <li> Mark Available</li>
            <li> Sell Medicine</li>
          </ul>
          <a href="/pharmacy" class="inline-block bg-purple-600 text-white px-3 py-1 rounded text-xs hover:bg-purple-700">
            Go to Pharmacy →
          </a>
        </div>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      
      <a href="/track" class="bg-white border hover:border-indigo-400 rounded-lg p-4 text-center shadow hover:shadow-md transition">
        <div class="text-2xl mb-1">🔍</div>
        <div class="font-semibold text-gray-700 text-sm">Track Medicine</div>
      </a>
      <a href="/verify" class="bg-white border hover:border-indigo-400 rounded-lg p-4 text-center shadow hover:shadow-md transition">
        <div class="text-2xl mb-1">📱</div>
        <div class="font-semibold text-gray-700 text-sm">QR Verify</div>
      </a>
      
    </div>

   

  </div>

  <%- include('_loading') %>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/5.7.2/ethers.umd.min.js"></script>
  <script>const CONTRACT_ADDRESS = "<%= CONTRACT_ADDRESS %>";</script>
  <script src="/ui.js"></script>
  <script>
    async function onContractReady() {
      // Show loading
      document.getElementById("statsLoading").classList.remove("hidden");

      try {
        // Get all medicine IDs
        const ids = await contract.getAllMedicineIds();
        const total = ids.length;
        document.getElementById("totalMedicines").textContent = total;

        // Count by status
        let manufactured = 0, atPharmacy = 0, sold = 0;
        for (const id of ids) {
          try {
            const m      = await contract.getMedicine(id);
            const status = Number(m[9]);
            if (status === 0) manufactured++;
            if (status === 4) atPharmacy++;
            if (status === 5) sold++;
          } catch(e) {}
        }
        document.getElementById("manufacturedCount").textContent = manufactured;
        document.getElementById("pharmacyCount").textContent     = atPharmacy;
        document.getElementById("soldCount").textContent         = sold;

      } catch(e) {
        console.error("Stats load error:", e);
        document.getElementById("totalMedicines").textContent    = "?";
        document.getElementById("manufacturedCount").textContent = "?";
        document.getElementById("pharmacyCount").textContent     = "?";
        document.getElementById("soldCount").textContent         = "?";
      } finally {
        document.getElementById("statsLoading").classList.add("hidden");
      }

      // Load recent events
      try {
        const events      = await fetchAllEvents();
        const activityEl  = document.getElementById("recentActivity");

        if (events.length === 0) {
          activityEl.textContent = "No blockchain events found yet. Add a medicine first!";
        } else {
          activityEl.innerHTML = events.slice(0, 6).map(e => {
            const mid = e.args?.[0] || "";
            return `<div class="border-b py-2 flex justify-between items-center">
              <div>
                <span class="font-semibold text-indigo-600 text-xs">${e.type}</span>
                ${mid ? `<span class="ml-2 text-gray-500 text-xs">ID: ${mid}</span>` : ""}
              </div>
              <div class="flex items-center gap-2">
                <span class="text-gray-400 text-xs">Block #${e.blockNumber}</span>
                <a href="https://hoodi.etherscan.io/tx/${e.txHash}"
                  target="_blank" class="text-blue-400 underline text-xs">Tx ↗</a>
              </div>
            </div>`;
          }).join("");
        }

        // Live listener
        listenToEvents((event) => {
          const el = document.getElementById("recentActivity");
          el.innerHTML = `
            <div class="border-b py-2 bg-green-50 rounded px-2">
              <span class="font-semibold text-green-600 text-xs">🔔 LIVE: ${event.type}</span>
              <span class="ml-2 text-gray-500 text-xs">ID: ${event.id || ""}</span>
            </div>` + el.innerHTML;

          // Update total count live
          if (event.type === "MedicineAdded") {
            const cur = parseInt(document.getElementById("totalMedicines").textContent) || 0;
            document.getElementById("totalMedicines").textContent = cur + 1;
          }
        });

      } catch(e) {
        console.error("Events load error:", e);
        document.getElementById("recentActivity").textContent = "Could not load events.";
      }
    }
  </script>
</body>
</html>
