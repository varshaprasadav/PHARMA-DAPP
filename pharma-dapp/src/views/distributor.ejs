<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Distributor – PharmaChain</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <%- include('_nav') %>

  <div class="max-w-2xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-bold text-yellow-600 mb-2">🚚 Distributor Dashboard</h1>
    

    <div id="walletInfo" class="hidden bg-indigo-50 border border-indigo-200 rounded-lg p-3 mb-4 text-sm text-indigo-700">
      👛 <strong id="walletAddress"></strong> &nbsp;|&nbsp; 
    </div>
    <button id="connectBtn" onclick="connectWallet()"
      class="bg-indigo-600 text-white px-4 py-2 rounded mb-6 hover:bg-indigo-700">
      🔗 Connect Wallet
    </button>

    <div id="successMsg" class="hidden bg-green-100 text-green-700 border border-green-300 rounded p-3 mb-4"></div>
    <div id="errorMsg"   class="hidden bg-red-100   text-red-700   border border-red-300   rounded p-3 mb-4"></div>
    <div id="txHashBox"  class="hidden bg-blue-50   text-blue-700  border border-blue-200  rounded p-3 mb-4 text-sm break-all"></div>

    <div class="bg-white rounded-lg shadow p-6 space-y-4 mb-6 border-l-4 border-green-400">
      <span class="bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded">
        STEP 3 — Confirm Receipt (Account 2 — Distributor)
      </span>
      <h2 class="font-bold text-gray-700">Confirm Receipt from Manufacturer</h2>
      <p class="text-xs text-gray-400">
        ⚠️ <strong>MetaMask must be on Account 2</strong> to do this.
      </p>
      <input id="rMedicineId" placeholder="Medicine ID (e.g. MED001)"
        class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-300" />
      <button onclick="handleReceive()"
        class="w-full bg-green-600 text-white py-2 rounded font-semibold hover:bg-green-700 transition">
        ✅ Confirm Receipt
      </button>
    </div>

    <div class="bg-white rounded-lg shadow p-6 space-y-4 border-l-4 border-blue-400">
      <span class="bg-blue-100 text-blue-700 text-xs font-bold px-2 py-1 rounded">
        STEP 4 — Send to Pharmacy (Account 2 — Distributor)
      </span>
      <h2 class="font-bold text-gray-700">Send Medicine to Pharmacy</h2>
      <p class="text-xs text-gray-400">
        ⚠️ <strong>MetaMask must be on Account 2</strong> to do this.
      </p>
      <input id="pMedicineId" placeholder="Medicine ID (e.g. MED001)"
        class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" />
      <input id="pName" placeholder="Pharmacy Name (e.g. City Pharmacy)"
        class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" />
      <input id="pAddress" placeholder="Pharmacy Wallet Address (Account 3: 0x...)"
        class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300" />
      <button onclick="handleSendToPharmacy()"
        class="w-full bg-blue-600 text-white py-2 rounded font-semibold hover:bg-blue-700 transition">
        🏪 Send to Pharmacy
      </button>
    </div>

  </div>

  <%- include('_loading') %>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/5.7.2/ethers.umd.min.js"></script>
  <script>const CONTRACT_ADDRESS = "<%= CONTRACT_ADDRESS %>";</script>
  <script src="/ui.js"></script>
  <script>
    function clearMsgs() {
      ["successMsg","errorMsg","txHashBox"].forEach(x =>
        document.getElementById(x).classList.add("hidden"));
    }
    async function handleReceive() {
      if (!contract) return alert("Connect wallet first.");
      const id = document.getElementById("rMedicineId").value.trim();
      if (!id) return alert("Enter Medicine ID.");
      clearMsgs();
      await receiveByDistributor(id);
    }
    async function handleSendToPharmacy() {
      if (!contract) return alert("Connect wallet first.");
      const id   = document.getElementById("pMedicineId").value.trim();
      const name = document.getElementById("pName").value.trim();
      const addr = document.getElementById("pAddress").value.trim();
      if (!id || !name || !addr) return alert("Please fill all 3 fields.");
      if (!addr.startsWith("0x") || addr.length !== 42) return alert("Invalid wallet address.");
      clearMsgs();
      await assignPharmacy(id, name, addr);
    }
  </script>
</body>
</html>
