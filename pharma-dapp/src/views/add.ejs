<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Medicine – PharmaChain</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <%- include('_nav') %>

  <div class="max-w-2xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-bold text-indigo-700 mb-2">🏭 Manufacturer Dashboard</h1>
    <p class="text-gray-500 text-sm mb-6">
      Role: <strong>Manufacturer (Account 1)</strong> — Add medicine and assign distributor.
    </p>

    <div id="walletInfo" class="hidden bg-indigo-50 border border-indigo-200 rounded-lg p-3 mb-4 text-sm text-indigo-700">
       <strong id="walletAddress"></strong> &nbsp;|&nbsp; 
    </div>
    <button id="connectBtn" onclick="connectWallet()"
      class="bg-indigo-600 text-white px-4 py-2 rounded mb-6 hover:bg-indigo-700">
      🔗 Connect Wallet
    </button>

    <div id="successMsg" class="hidden bg-green-100 text-green-700 border border-green-300 rounded p-3 mb-4"></div>
    <div id="errorMsg"   class="hidden bg-red-100   text-red-700   border border-red-300   rounded p-3 mb-4"></div>
    <div id="txHashBox"  class="hidden bg-blue-50   text-blue-700  border border-blue-200  rounded p-3 mb-4 text-sm break-all"></div>

    <div class="bg-white rounded-lg shadow p-6 space-y-4 border-l-4 border-indigo-400 mb-6">
      <span class="bg-indigo-100 text-indigo-700 text-xs font-bold px-2 py-1 rounded">
        STEP 1 — Add Medicine to Blockchain
      </span>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Medicine ID <span class="text-red-500">*</span></label>
        <input id="medicineId" type="text" placeholder="e.g. MED001"
          class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Medicine Name <span class="text-red-500">*</span></label>
        <input id="name" type="text" placeholder="e.g. Paracetamol 500mg"
          class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Batch Number</label>
        <input id="batchNumber" type="text" placeholder="e.g. BATCH-2024-01"
          class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Manufacturing Date</label>
          <input id="manufacturingDate" type="date"
            class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Expiry Date</label>
          <input id="expiryDate" type="date"
            class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Manufacturer Name</label>
        <input id="manufacturerName" type="text" placeholder="e.g. ABC Pharma Ltd"
          class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
      </div>

      <button onclick="handleAdd()"
        class="w-full bg-indigo-600 text-white py-2 rounded font-semibold hover:bg-indigo-700 transition">
        🏭 Add to Blockchain
      </button>
    </div>

    <div id="qrBox" class="hidden bg-white rounded-lg shadow p-6 text-center mb-6">
      <h2 class="font-bold text-gray-700 mb-3">📱 QR Code Generated</h2>
      <div id="qrCanvas" class="inline-block border rounded p-2 bg-white shadow mb-2"></div>
      <div id="savedQrBox" class="hidden mt-3">
        <img id="qrImage" src="" alt="Saved QR PNG" class="mx-auto border rounded" style="width:160px" />
        <p class="text-xs text-gray-400 mt-1">Saved QR PNG</p>
      </div>
      <div class="mt-3">
        <button id="downloadBtn" class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-3 py-1 rounded text-xs">
          ⬇ Download QR
        </button>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6 space-y-4 border-l-4 border-yellow-400 mb-6">
      <span class="bg-yellow-100 text-yellow-700 text-xs font-bold px-2 py-1 rounded">
        STEP 2 — Assign Distributor (Account 1 — Manufacturer)
      </span>
      <h2 class="font-bold text-gray-700">Ship Medicine to Distributor</h2>
      <p class="text-xs text-gray-400">
        Manufacturer transfers medicine ownership to the distributor.<br/>
        ⚠️ <strong>MetaMask must be on Account 1</strong> to do this.
      </p>

      <input id="dMedicineId" placeholder="Medicine ID (e.g. MED001)"
        class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-300" />
      <input id="dName" placeholder="Distributor Name (e.g. XYZ Distributors)"
        class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-300" />
      <input id="dAddress" placeholder="Distributor Wallet Address (Account 2: 0x...)"
        class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-yellow-300" />

      <div class="bg-gray-50 rounded p-2 text-xs text-gray-500">
        Currently connected: <strong id="currentAccount" class="font-mono text-indigo-600">—</strong>
      </div>

      <button onclick="handleAssignDist()"
        class="w-full bg-yellow-500 text-white py-2 rounded font-semibold hover:bg-yellow-600 transition">
        📦 Assign Distributor
      </button>
    </div>

  </div>

  <%- include('_loading') %>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/5.7.2/ethers.umd.min.js"></script>
  <script>const CONTRACT_ADDRESS = "<%= CONTRACT_ADDRESS %>";</script>
  <script src="/ui.js"></script>
  <script src="/qr.js"></script>
  <script>

    async function onContractReady() {
      const address = await signer.getAddress();
      document.getElementById("currentAccount").textContent = address;
    }

    function clearMsgs() {
      ["successMsg","errorMsg","txHashBox"].forEach(id =>
        document.getElementById(id).classList.add("hidden"));
    }

    async function handleAdd() {
      if (!contract) return alert("Connect wallet first.");

      const data = {
        medicineId:        document.getElementById("medicineId").value.trim(),
        name:              document.getElementById("name").value.trim(),
        batchNumber:       document.getElementById("batchNumber").value.trim(),
        manufacturingDate: document.getElementById("manufacturingDate").value,
        expiryDate:        document.getElementById("expiryDate").value,
        manufacturerName:  document.getElementById("manufacturerName").value.trim(),
      };

      if (!data.medicineId || !data.name) return alert("Medicine ID and Name are required.");
      clearMsgs();

      setLoading(true, "Adding medicine to blockchain...");
      try {
        const tx = await contract.addMedicine(
          data.medicineId, data.name, data.batchNumber,
          data.manufacturingDate, data.expiryDate, data.manufacturerName
        );
        showTxHash(tx.hash);
        await tx.wait();

        const qrPath = await generateAndSaveQR(data, tx.hash);
        document.getElementById("qrBox").classList.remove("hidden");
        generateQRCode("qrCanvas", data);
        if (qrPath) showQRImage(qrPath, "qrImage", "savedQrBox");
        document.getElementById("downloadBtn").onclick = () => downloadQR(data.medicineId);

        document.getElementById("dMedicineId").value = data.medicineId;

        showSuccess("✅ Medicine added! ID: " + data.medicineId + " — Now fill Step 2 to assign distributor.");
      } catch (err) {
        showError(err.reason || err.message);
      } finally {
        setLoading(false);
      }
    }

   async function handleAssignDist() {
      if (!contract) return alert("Connect wallet first.");
      const id   = document.getElementById("dMedicineId").value.trim();
      const name = document.getElementById("dName").value.trim();
      const addr = document.getElementById("dAddress").value.trim();
      if (!id || !name || !addr) return alert("Please fill all 3 fields.");
      if (!addr.startsWith("0x") || addr.length !== 42) return alert("Invalid wallet address.");
      clearMsgs();
      await assignDistributor(id, name, addr);
    }

  </script>
</body>
</html>
EOF