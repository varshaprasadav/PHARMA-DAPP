<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Medicine List – PharmaChain</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <%- include('_nav') %>

  <div class="max-w-5xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-bold text-indigo-700 mb-2">💊 All Medicines</h1>
    <p class="text-gray-500 text-sm mb-6">All medicines registered on the blockchain.</p>

    <div id="walletInfo" class="hidden bg-indigo-50 border border-indigo-200 rounded-lg p-3 mb-4 text-sm text-indigo-700">
      👛 <strong id="walletAddress"></strong> &nbsp;|&nbsp; 
    </div>
    <button id="connectBtn" onclick="connectWallet()"
      class="bg-indigo-600 text-white px-4 py-2 rounded mb-6 hover:bg-indigo-700">
      🔗 Connect Wallet
    </button>

    <div id="errorMsg" class="hidden bg-red-100 text-red-700 border border-red-300 rounded p-3 mb-4"></div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <div class="bg-white rounded-lg shadow p-4 text-center">
        <div class="text-3xl font-bold text-indigo-600" id="totalCount">—</div>
        <div class="text-gray-500 text-xs mt-1">Total Medicines</div>
      </div>
      <div class="bg-white rounded-lg shadow p-4 text-center">
        <div class="text-3xl font-bold text-blue-500" id="manufacturedCount">—</div>
        <div class="text-gray-500 text-xs mt-1">Manufactured</div>
      </div>
      <div class="bg-white rounded-lg shadow p-4 text-center">
        <div class="text-3xl font-bold text-green-500" id="availableCount">—</div>
        <div class="text-gray-500 text-xs mt-1">At Pharmacy</div>
      </div>
      <div class="bg-white rounded-lg shadow p-4 text-center">
        <div class="text-3xl font-bold text-gray-500" id="soldCount">—</div>
        <div class="text-gray-500 text-xs mt-1">Sold</div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-4 mb-6 flex gap-2">
      <input id="searchInput" placeholder="Search by Medicine ID or Name..."
        oninput="filterTable()"
        class="flex-1 border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
      <select id="statusFilter" onchange="filterTable()"
        class="border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
        <option value="">All Status</option>
        <option value="0">Manufactured</option>
        <option value="1">Shipped to Distributor</option>
        <option value="2">Received by Distributor</option>
        <option value="3">Sent to Pharmacy</option>
        <option value="4">Available at Pharmacy</option>
        <option value="5">Sold</option>
      </select>
    </div>

    <div id="tableLoading" class="hidden text-center py-10">
      <div class="text-4xl animate-spin inline-block">⚙️</div>
      <p class="text-gray-500 mt-2">Loading medicines from blockchain...</p>
    </div>

    <div class="bg-white rounded-lg shadow overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-indigo-50 text-indigo-700">
          <tr>
            <th class="px-4 py-3 text-left">Medicine ID</th>
            <th class="px-4 py-3 text-left">Name</th>
            <th class="px-4 py-3 text-left">Batch</th>
            <th class="px-4 py-3 text-left">Manufacturer</th>
            <th class="px-4 py-3 text-left">Expiry</th>
            <th class="px-4 py-3 text-left">Status</th>
            <th class="px-4 py-3 text-left">Action</th>
          </tr>
        </thead>
        <tbody id="medicineTableBody">
          <tr>
            <td colspan="7" class="px-4 py-8 text-center text-gray-400">
              Connect wallet to load medicines...
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div id="noResults" class="hidden text-center py-6 text-gray-400">
      No medicines found matching your search.
    </div>

  </div>

  <%- include('_loading') %>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/5.7.2/ethers.umd.min.js"></script>
  <script>const CONTRACT_ADDRESS = "<%= CONTRACT_ADDRESS %>";</script>
  <script src="/ui.js"></script>
  <script>
    let allMedicines = [];

    async function onContractReady() {
      await loadAllMedicines();
    }

    async function loadAllMedicines() {
      document.getElementById("tableLoading").classList.remove("hidden");
      document.getElementById("medicineTableBody").innerHTML = "";

      try {
        const ids = await contract.getAllMedicineIds();
        document.getElementById("totalCount").textContent = ids.length;

        if (ids.length === 0) {
          document.getElementById("medicineTableBody").innerHTML =
            `<tr><td colspan="7" class="px-4 py-8 text-center text-gray-400">
              No medicines found on blockchain.
            </td></tr>`;
          return;
        }

        allMedicines = [];
        for (const id of ids) {
          try {
            const m = await contract.getMedicine(id);
            allMedicines.push({
              medicineId:        m[0],
              name:              m[1],
              batchNumber:       m[2],
              manufacturingDate: m[3],
              expiryDate:        m[4],
              manufacturerName:  m[5],
              distributorName:   m[6],
              pharmacyName:      m[7],
              currentOwner:      m[8],
              currentStatus:     Number(m[9]),
              timestamp:         Number(m[10]),
            });
          } catch (e) {
            console.warn("Could not fetch medicine:", id);
          }
        }

        updateStats();

        renderTable(allMedicines);

      } catch (err) {
        showError("Failed to load medicines: " + err.message);
      } finally {
        document.getElementById("tableLoading").classList.add("hidden");
      }
    }

    function updateStats() {
      document.getElementById("totalCount").textContent       = allMedicines.length;
      document.getElementById("manufacturedCount").textContent = allMedicines.filter(m => m.currentStatus === 0).length;
      document.getElementById("availableCount").textContent    = allMedicines.filter(m => m.currentStatus === 4).length;
      document.getElementById("soldCount").textContent         = allMedicines.filter(m => m.currentStatus === 5).length;
    }

    function renderTable(medicines) {
      const tbody = document.getElementById("medicineTableBody");
      const noResults = document.getElementById("noResults");

      if (medicines.length === 0) {
        tbody.innerHTML = "";
        noResults.classList.remove("hidden");
        return;
      }

      noResults.classList.add("hidden");
      tbody.innerHTML = medicines.map(m => `
        <tr class="border-t hover:bg-gray-50 transition">
          <td class="px-4 py-3 font-mono font-bold text-indigo-600">${m.medicineId}</td>
          <td class="px-4 py-3 font-medium">${m.name}</td>
          <td class="px-4 py-3 text-gray-500">${m.batchNumber || "—"}</td>
          <td class="px-4 py-3 text-gray-500">${m.manufacturerName}</td>
          <td class="px-4 py-3 text-gray-500">${m.expiryDate || "—"}</td>
          <td class="px-4 py-3">${statusBadge(m.currentStatus)}</td>
          <td class="px-4 py-3">
            <a href="/track?id=${m.medicineId}"
              class="text-indigo-600 underline text-xs hover:text-indigo-800">
              View Details
            </a>
          </td>
        </tr>
      `).join("");
    }

    function filterTable() {
      const search = document.getElementById("searchInput").value.toLowerCase();
      const status = document.getElementById("statusFilter").value;

      const filtered = allMedicines.filter(m => {
        const matchSearch = !search ||
          m.medicineId.toLowerCase().includes(search) ||
          m.name.toLowerCase().includes(search) ||
          m.manufacturerName.toLowerCase().includes(search) ||
          m.batchNumber.toLowerCase().includes(search);

        const matchStatus = status === "" || m.currentStatus === Number(status);

        return matchSearch && matchStatus;
      });

      renderTable(filtered);
    }
  </script>

  <script>
    window.addEventListener("load", () => {
      const params = new URLSearchParams(window.location.search);
      const id = params.get("id");
      if (id) {
        const input = document.getElementById("trackId");
        if (input) { input.value = id; }
      }
    });
  </script>
</body>
</html>
