<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pharmacy – PharmaChain</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <%- include('_nav') %>

  <div class="max-w-2xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-bold text-purple-600 mb-2">💊 Pharmacy Dashboard</h1>
    <p class="text-gray-500 text-sm mb-6">
      Role: <strong>Pharmacy (Account 3)</strong> — Receive medicine from distributor, mark available, and sell.
    </p>

    <div id="walletInfo" class="hidden bg-indigo-50 border border-indigo-200 rounded-lg p-3 mb-4 text-sm text-indigo-700">
      👛 <strong id="walletAddress"></strong> &nbsp;|&nbsp; 🌐 <strong id="networkName"></strong>
    </div>
    <button id="connectBtn" onclick="connectWallet()"
      class="bg-indigo-600 text-white px-4 py-2 rounded mb-6 hover:bg-indigo-700">
      🔗 Connect Wallet
    </button>

    <div id="successMsg" class="hidden bg-green-100 text-green-700 border border-green-300 rounded p-3 mb-4"></div>
    <div id="errorMsg"   class="hidden bg-red-100   text-red-700   border border-red-300   rounded p-3 mb-4"></div>
    <div id="txHashBox"  class="hidden bg-blue-50   text-blue-700  border border-blue-200  rounded p-3 mb-4 text-sm break-all"></div>

    <div class="bg-white rounded-lg shadow p-6 space-y-4 mb-6 border-l-4 border-purple-400">
      <div class="flex items-center gap-2 mb-1">
        <span class="bg-purple-100 text-purple-700 text-xs font-bold px-2 py-1 rounded">STEP 4 — Pharmacy</span>
      </div>
      <h2 class="font-bold text-gray-700">Mark Medicine as Available</h2>
      <p class="text-xs text-gray-400">Pharmacy (Account 3) confirms medicine is on the shelf.</p>
      <input id="aMedicineId" placeholder="Medicine ID (e.g. MED001)"
        class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-300" />
      <button onclick="handleMarkAvail()"
        class="w-full bg-purple-600 text-white py-2 rounded font-semibold hover:bg-purple-700 transition">
        🏷️ Mark as Available
      </button>
    </div>

    <div class="bg-white rounded-lg shadow p-6 space-y-4 border-l-4 border-red-400">
      <div class="flex items-center gap-2 mb-1">
        <span class="bg-red-100 text-red-700 text-xs font-bold px-2 py-1 rounded">STEP 5 — Pharmacy</span>
      </div>
      <h2 class="font-bold text-gray-700">Sell Medicine to Customer</h2>
      <p class="text-xs text-gray-400">Pharmacy (Account 3) marks medicine as sold.</p>
      <input id="sMedicineId" placeholder="Medicine ID (e.g. MED001)"
        class="w-full border rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-300" />
      <button onclick="handleSell()"
        class="w-full bg-red-500 text-white py-2 rounded font-semibold hover:bg-red-600 transition">
        💰 Sell Medicine
      </button>
    </div>

  </div>

  <%- include('_loading') %>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/5.7.2/ethers.umd.min.js"></script>
  <script>const CONTRACT_ADDRESS = "<%= CONTRACT_ADDRESS %>";</script>
  <script src="/ui.js"></script>
  <script>
    function clearMsgs() {
      ["successMsg","errorMsg","txHashBox"].forEach(x =>
        document.getElementById(x).classList.add("hidden"));
    }

    async function handleMarkAvail() {
      if (!contract) return alert("Connect wallet first.");
      const id = document.getElementById("aMedicineId").value.trim();
      if (!id) return alert("Enter Medicine ID.");
      clearMsgs();
      await markAvailable(id);
    }

    async function handleSell() {
      if (!contract) return alert("Connect wallet first.");
      const id = document.getElementById("sMedicineId").value.trim();
      if (!id) return alert("Enter Medicine ID.");
      clearMsgs();
      await sellMedicine(id);
    }
  </script>
</body>
</html>
